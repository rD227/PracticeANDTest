#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n, m;
    cin >> n >> m;
    vector<int> v(n);
    for (int i = 0; i < n; i++)
        cin >> v[i];

    while (m--) {
        int q;
        cin >> q;
        int pos = lower_bound(v.begin(), v.end(), q) - v.begin();
        if (pos < n && v[pos] == q)
            cout << pos + 1 << " ";
        else
            cout << -1 << " ";
    }
    return 0;
}
