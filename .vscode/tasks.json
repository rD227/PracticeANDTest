{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "cppbuild",
      "label": "C/C++: g++.exe build active file",
      "command": "D:\\x86_64-15.2.0-release-posix-seh-ucrt-rt_v13-rev0\\mingw64\\bin\\g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}\\${fileBasenameNoExtension}.exe"
      ],
      "options": { "cwd": "${fileDirname}" },
      "problemMatcher": ["$gcc"],
      "group": { "kind": "build", "isDefault": true },
      "detail": "Build current C++ file for debugging"
    },
    {
      "label": "build and run C++",
      "type": "shell",
      "command": "D:\\x86_64-15.2.0-release-posix-seh-ucrt-rt_v13-rev0\\mingw64\\bin\\g++.exe",
      "args": [
        "${file}",
        "-g",
        "-o",
        "${fileDirname}\\${fileBasenameNoExtension}.exe",
        "-fexec-charset=GBK"
      ],
      "options": { "cwd": "${fileDirname}" },
      "group": { "kind": "build", "isDefault": false },
      "problemMatcher": [],
      "detail": "使用 g++ 编译并运行 C++ 程序"      
    }
  ]
}
